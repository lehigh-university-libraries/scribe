# LLM Provider Configuration
# LLM_PROVIDER: "ollama" (default), "openai", or "gemini"
LLM_PROVIDER=ollama

# Database configuration used by docker-compose.
# The passwords are generated into ./secrets/ by generate-secrets.sh.
MARIADB_DATABASE=scribe
MARIADB_USER=scribe

# Local development normally uses `docker compose up --build`, but deployed
# environments set this to the exact GHCR image built in CI.
SCRIBE_API_IMAGE=ghcr.io/lehigh-university-libraries/scribe:main

# Ollama Configuration (used when LLM_PROVIDER=ollama)
# OLLAMA_URL: URL of your Ollama instance (defaults to http://localhost:11434)
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL: Model to use for transcription (defaults to mistral-small3.2:24b)
# Vision-capable models: mistral-small3.2:24b, llava, llava:13b, llava:34b, bakllava, moondream
OLLAMA_MODEL=mistral-small3.2:24b

# OpenAI Configuration (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY: Your OpenAI API key
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# OPENAI_MODEL: OpenAI model to use (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o
# OPENAI_MODELS: Comma-separated list shown in UI model selector
OPENAI_MODELS=gpt-4o,gpt-4.1

# Gemini Configuration (used when LLM_PROVIDER=gemini)
# GEMINI_API_KEY: Your Gemini API key
GEMINI_API_KEY=
# GEMINI_MODEL: Default Gemini model
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODELS: Comma-separated list shown in UI model selector
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-pro

# Ollama model list shown in UI model selector
OLLAMA_MODELS=mistral-small3.2:24b,llava,bakllava

# Optional: Drupal integration URL template (for Drupal node ID processing)
DRUPAL_HOCR_URL=https://your-drupal-site.com/node/%s/hocr

# Optional: Public/base IIIF Image API URL used when generating session manifests.
# Example:
# manifest endpoint: /v1/ocr/runs/{session_id}/manifest
# image service in manifest: ${CANTALOUPE_IIIF_BASE}/{identifier}
CANTALOUPE_IIIF_BASE=/cantaloupe/iiif/2
# Optional: Internal IIIF URL used by API container for server-side fetch/crop calls.
# In docker-compose this should usually be the service DNS name.
CANTALOUPE_IIIF_INTERNAL_BASE=http://cantaloupe:8182/iiif/2
ANNOTATION_API_BASE=/
# Optional: comma-separated webhook endpoints that receive all emitted Scribe events
# as structured CloudEvents JSON via HTTP POST.
# Example:
# SCRIBE_WEBHOOK_URLS=http://islandora:8000/scribe/events,https://example.org/hooks/scribe
SCRIBE_WEBHOOK_URLS=

# Optional: annotation API base URL for Mirador annotation editor (frontend build-time var)
# If unset, frontend defaults to the current browser origin.
VITE_ANNOTATION_API_BASE=/

# Transcription Configuration
# BATCH_SIZE: Number of words to stitch together in a single image for LLM transcription
# Higher values = fewer API calls but potentially lower accuracy
# Lower values = more API calls but potentially higher accuracy
# Default: 10
BATCH_SIZE=10

# LINE_TRANSCRIBE_CONCURRENCY: Max concurrent line transcription requests for handwritten/custom flow
# Default: 5
LINE_TRANSCRIBE_CONCURRENCY=5

# Note: This application uses Tesseract for word detection and LLM (Ollama/OpenAI) for transcription
# Tesseract and ImageMagick are required for image processing operations
